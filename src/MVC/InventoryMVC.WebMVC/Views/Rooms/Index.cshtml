@model IEnumerable<Room>
@using Microsoft.AspNetCore.Mvc.Rendering
@{ ViewData["Title"] = "Rooms"; }

@{
    var groupByOptions = new SelectList(new[] {
        new { Value = "department", Text = "Department" },
        new { Value = "floor",      Text = "Floor" }
    }, "Value", "Text", ViewBag.GroupBy as string);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Rooms</h2>
    <a asp-action="Create" class="btn btn-dark">+ Room</a>
</div>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label small text-muted mb-1">Room #</label>
        <input type="search" name="q" value="@(ViewBag.Q ?? "")"
               class="form-control form-control-sm" placeholder="e.g. 101" />
    </div>
    <div class="col-md-3">
        <label class="form-label small text-muted mb-1">Department</label>
        <select name="departmentId" asp-items="ViewBag.DepartmentList" class="form-select form-select-sm">
            <option value="">— All —</option>
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label small text-muted mb-1">Floor</label>
        <select name="floor" asp-items="ViewBag.FloorList" class="form-select form-select-sm">
            <option value="">— All —</option>
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label small text-muted mb-1">Group by</label>
        <select name="groupBy" asp-items="groupByOptions" class="form-select form-select-sm">
            <option value="">— No grouping —</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-dark">Apply</button>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
    </div>
</form>

@{
    var gb = ViewBag.GroupBy as string;
    var groups = gb switch {
        "department" => Model.GroupBy(r => r.Department?.Name ?? "Unknown").OrderBy(g => g.Key),
        "floor"      => Model.GroupBy(r => $"Floor {r.Floor}").OrderBy(g => g.Key),
        _            => Model.GroupBy(r => string.Empty)
    };
}

<table class="table table-hover">
    <thead class="table-light">
        <tr><th>Room #</th><th>Floor</th><th>Department</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var group in groups)
        {
            if (!string.IsNullOrEmpty(group.Key))
            {
                <tr class="table-secondary">
                    <td colspan="4" class="fw-semibold">
                        @group.Key
                        <span class="badge bg-secondary ms-2">@group.Count()</span>
                    </td>
                </tr>
            }
            @foreach (var r in group)
            {
                <tr>
                    <td>@r.Number</td>
                    <td>@r.Floor</td>
                    <td>@r.Department?.Name</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@r.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
@if (!Model.Any()) { <p class="text-muted">No rooms found.</p> }

@model IEnumerable<Room>
@{ ViewData["Title"] = "Rooms"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Rooms</h2>
    <a asp-action="Create" class="btn btn-success">+ New Room</a>
</div>

<table class="table table-hover">
    <thead class="table-dark">
        <tr><th>Room #</th><th>Floor</th><th>Department</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.Number</td>
                <td>@r.Floor</td>
                <td>@r.Department?.Name</td>
                <td>
                    <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@r.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

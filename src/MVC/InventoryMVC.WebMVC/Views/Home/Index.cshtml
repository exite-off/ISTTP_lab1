@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h2>Dashboard</h2>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <p class="card-title fs-6 fw-semibold mb-1">Inventory Items</p>
                <p class="card-text text-muted small flex-grow-1">View and manage all inventory items, track status and ownership.</p>
                <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-sm btn-dark mt-2 align-self-start">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <p class="card-title fs-6 fw-semibold mb-1">Departments</p>
                <p class="card-text text-muted small flex-grow-1">Manage departments, their rooms and assigned personnel.</p>
                <a asp-controller="Departments" asp-action="Index" class="btn btn-sm btn-dark mt-2 align-self-start">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <p class="card-title fs-6 fw-semibold mb-1">Responsible Persons</p>
                <p class="card-text text-muted small flex-grow-1">Manage employees and their item assignments.</p>
                <a asp-controller="ResponsiblePersons" asp-action="Index" class="btn btn-sm btn-dark mt-2 align-self-start">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <p class="card-title fs-6 fw-semibold mb-1">Categories</p>
                <p class="card-text text-muted small flex-grow-1">Item classification (furniture, equipment, etc.).</p>
                <a asp-controller="Categories" asp-action="Index" class="btn btn-sm btn-outline-secondary mt-2 align-self-start">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <p class="card-title fs-6 fw-semibold mb-1">Vendors</p>
                <p class="card-text text-muted small flex-grow-1">Suppliers and their contact information.</p>
                <a asp-controller="Vendors" asp-action="Index" class="btn btn-sm btn-outline-secondary mt-2 align-self-start">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <p class="card-title fs-6 fw-semibold mb-1">Rooms</p>
                <p class="card-text text-muted small flex-grow-1">Physical locations where items are stored.</p>
                <a asp-controller="Rooms" asp-action="Index" class="btn btn-sm btn-outline-secondary mt-2 align-self-start">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0" style="background:#f8f9fb">
            <div class="card-body d-flex flex-column">
                <h6 class="card-title fw-semibold text-uppercase text-secondary mb-1" style="font-size:.7rem;letter-spacing:.06em">Audit</h6>
                <p class="card-title fs-6 fw-semibold mb-1">Change Log</p>
                <p class="card-text text-muted small flex-grow-1">History of item transfers and responsibility changes.</p>
                <a asp-controller="InventoryLogs" asp-action="Index" class="btn btn-sm btn-outline-secondary mt-2 align-self-start">Open</a>
            </div>
        </div>
    </div>
</div>

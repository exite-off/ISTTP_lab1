@model IEnumerable<InventoryItem>
@{ ViewData["Title"] = "Inventory Items"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Inventory Items</h2>
    <a asp-action="Create" class="btn btn-dark">+ Item</a>
</div>

<table class="table table-hover">
    <thead class="table-light">
        <tr>
            <th>Inv #</th><th>Name</th><th>Category</th>
            <th>Status</th><th>Room</th><th>Responsible</th><th>Price</th><th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.InventoryNumber</td>
                <td>@item.Name</td>
                <td>@item.Category?.Name</td>
                <td><span class="badge bg-info text-dark">@item.Status</span></td>
                <td>@item.Room?.Number / @item.Room?.Department?.Name</td>
                <td>@item.ResponsiblePerson?.FullName</td>
                <td>@item.Price.ToString("N2") @item.Currency</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="row mt-4">
    <div class="col-md-6">
        <p class="fw-semibold mb-1">Items by Category</p>
        <div id="chartByCategory"></div>
    </div>
    <div class="col-md-6">
        <p class="fw-semibold mb-1">Items by Status</p>
        <div id="chartByStatus"></div>
    </div>
</div>

@section Scripts {
<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
<script type="text/javascript">
    google.charts.load('current', { packages: ['corechart'] });
    google.charts.setOnLoadCallback(drawCharts);

    function drawCharts() {
        drawCategoryChart();
        drawStatusChart();
    }

    function drawCategoryChart() {
        fetch('/api/charts/countByCategory')
            .then(r => r.json())
            .then(data => {
                const table = new google.visualization.DataTable();
                table.addColumn('string', 'Category');
                table.addColumn('number', 'Items');
                data.forEach(item => table.addRow([item.category, item.count]));

                const chart = new google.visualization.PieChart(
                    document.getElementById('chartByCategory'));
                chart.draw(table, {
                    width: '100%', height: 320,
                    legend: { position: 'right' },
                    chartArea: { width: '65%', height: '80%' }
                });
            });
    }

    function drawStatusChart() {
        fetch('/api/charts/countByStatus')
            .then(r => r.json())
            .then(data => {
                const table = new google.visualization.DataTable();
                table.addColumn('string', 'Status');
                table.addColumn('number', 'Items');
                data.forEach(item => table.addRow([item.status, item.count]));

                const chart = new google.visualization.ColumnChart(
                    document.getElementById('chartByStatus'));
                chart.draw(table, {
                    width: '100%', height: 320,
                    legend: { position: 'none' },
                    chartArea: { width: '75%', height: '70%' },
                    vAxis: { minValue: 0, format: '0' }
                });
            });
    }
</script>
}

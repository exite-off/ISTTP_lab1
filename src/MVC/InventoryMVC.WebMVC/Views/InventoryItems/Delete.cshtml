@model InventoryItem
@{ ViewData["Title"] = "Delete Item"; }

<h2 class="text-danger">Delete Item</h2>
<p>Are you sure you want to delete <strong>@Model.Name</strong> (Inv# @Model.InventoryNumber)?</p>
<dl class="row">
    <dt class="col-sm-3">Category</dt><dd class="col-sm-9">@Model.Category?.Name</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Responsible</dt><dd class="col-sm-9">@Model.ResponsiblePerson?.FullName</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

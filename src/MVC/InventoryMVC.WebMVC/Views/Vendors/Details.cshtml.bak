@model Vendor
@{ ViewData["Title"] = Model.Name; }

<h2>@Model.Name</h2>
<dl class="row mb-4">
    <dt class="col-sm-3">Contact Phone</dt><dd class="col-sm-9">@Model.ContactPhone</dd>
    <dt class="col-sm-3">Email</dt><dd class="col-sm-9">@Model.Email</dd>
    <dt class="col-sm-3">Address</dt><dd class="col-sm-9">@Model.Address</dd>
</dl>

<div class="d-flex gap-2 mb-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>

<h5>Supplied Items (@Model.InventoryItems.Count)</h5>
@if (Model.InventoryItems.Any())
{
    <table class="table table-sm">
        <thead><tr><th>Inv #</th><th>Name</th><th>Status</th></tr></thead>
        <tbody>
            @foreach (var item in Model.InventoryItems)
            {
                <tr>
                    <td>@item.InventoryNumber</td>
                    <td><a asp-controller="InventoryItems" asp-action="Details" asp-route-id="@item.Id">@item.Name</a></td>
                    <td><span class="badge bg-info text-dark">@item.Status</span></td>
                </tr>
            }
        </tbody>
    </table>
}
else { <p class="text-muted">No items from this vendor.</p> }

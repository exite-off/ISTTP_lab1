@model Department
@{ ViewData["Title"] = "Delete Department"; }

<h2 class="text-danger">Delete Department</h2>
<p>Are you sure you want to delete <strong>@Model.Name</strong>?</p>
<dl class="row">
    <dt class="col-sm-3">Address</dt><dd class="col-sm-9">@Model.Address</dd>
    <dt class="col-sm-3">Phone</dt><dd class="col-sm-9">@Model.Phone</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

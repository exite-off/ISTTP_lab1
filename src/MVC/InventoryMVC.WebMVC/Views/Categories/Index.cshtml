@model IEnumerable<Category>
@{ ViewData["Title"] = "Categories"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Categories</h2>
    <a asp-action="Create" class="btn btn-dark">+ Category</a>
</div>

<table class="table table-hover">
    <thead class="table-light">
        <tr><th>Name</th><th>Description</th><th>Items</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Name</td>
                <td>@c.Description</td>
                <td><span class="badge bg-secondary">@c.InventoryItems.Count</span></td>
                <td>
                    <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

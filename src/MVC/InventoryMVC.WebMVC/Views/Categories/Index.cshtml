@model IEnumerable<Category>
@{ ViewData["Title"] = "Categories"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Categories</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-dark">+ Category</a>
    }
</div>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-4">
        <label class="form-label small text-muted mb-1">Search by name</label>
        <input type="search" name="q" value="@(ViewBag.Q ?? "")"
               class="form-control form-control-sm" placeholder="Category name..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-dark">Apply</button>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
    </div>
</form>

<table class="table table-hover">
    <thead class="table-light">
        <tr><th>Name</th><th>Description</th><th>Items</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Name</td>
                <td>@c.Description</td>
                <td><span class="badge bg-secondary">@c.InventoryItems.Count</span></td>
                <td>
                    <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-info">Details</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
@if (!Model.Any()) { <p class="text-muted">No categories found.</p> }

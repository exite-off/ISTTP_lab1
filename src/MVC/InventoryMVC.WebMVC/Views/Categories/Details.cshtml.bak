@model Category
@{ ViewData["Title"] = Model.Name; }

<h2>@Model.Name</h2>
<p class="text-muted">@Model.Description</p>

<div class="d-flex gap-2 mb-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>

<h5>Inventory Items (@Model.InventoryItems.Count)</h5>
@if (Model.InventoryItems.Any())
{
    <table class="table table-sm">
        <thead><tr><th>Inv #</th><th>Name</th><th>Status</th><th>Responsible</th></tr></thead>
        <tbody>
            @foreach (var item in Model.InventoryItems)
            {
                <tr>
                    <td>@item.InventoryNumber</td>
                    <td><a asp-controller="InventoryItems" asp-action="Details" asp-route-id="@item.Id">@item.Name</a></td>
                    <td><span class="badge bg-info text-dark">@item.Status</span></td>
                    <td>@item.ResponsiblePerson?.FullName</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No items in this category.</p>
}

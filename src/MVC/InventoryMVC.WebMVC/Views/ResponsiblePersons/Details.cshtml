@model ResponsiblePerson
@{ ViewData["Title"] = Model.FullName; }

<h2>@Model.FullName</h2>
<dl class="row mb-4">
    <dt class="col-sm-3">Position</dt><dd class="col-sm-9">@Model.Position</dd>
    <dt class="col-sm-3">Email</dt><dd class="col-sm-9">@Model.Email</dd>
    <dt class="col-sm-3">Department</dt><dd class="col-sm-9">@Model.Department?.Name</dd>
</dl>
<div class="d-flex gap-2 mb-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>

<h5>Assigned Items (@Model.InventoryItems.Count)</h5>
@if (Model.InventoryItems.Any())
{
    <table class="table table-sm">
        <thead><tr><th>Inv #</th><th>Name</th><th>Category</th><th>Status</th><th></th></tr></thead>
        <tbody>
            @foreach (var item in Model.InventoryItems)
            {
                <tr>
                    <td>@item.InventoryNumber</td>
                    <td>@item.Name</td>
                    <td>@item.Category?.Name</td>
                    <td><span class="badge bg-info text-dark">@item.Status</span></td>
                    <td><a asp-controller="InventoryItems" asp-action="Details" asp-route-id="@item.Id">Details</a></td>
                </tr>
            }
        </tbody>
    </table>
}
else { <p class="text-muted">No items assigned.</p> }

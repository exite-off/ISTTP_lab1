@page
@model LoginModel
@{ ViewData["Title"] = "Log in"; }

<div class="row justify-content-center" style="margin-top: 4rem;">
    <div class="col-sm-10 col-md-7 col-lg-5 col-xl-4">

        <div class="card p-4 p-md-5">
            <h4 class="fw-semibold mb-1" style="color:#1a2332;">Welcome back</h4>
            <p class="text-muted small mb-4">Sign in to your account</p>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control"
                           autocomplete="username" placeholder="you@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <input asp-for="Input.Password" class="form-control"
                           autocomplete="current-password" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label small">Remember me</label>
                </div>

                <button type="submit" class="btn btn-dark w-100">Log in</button>
            </form>

            <hr class="my-4" />

            <p class="text-center small mb-0">
                Don't have an account?
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register</a>
            </p>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

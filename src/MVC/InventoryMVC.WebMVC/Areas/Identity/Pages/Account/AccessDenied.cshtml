@page
@{ ViewData["Title"] = "Access Denied"; }

<div class="row justify-content-center" style="margin-top: 4rem;">
    <div class="col-sm-10 col-md-6 col-lg-5 col-xl-4 text-center">

        <div class="card p-4 p-md-5">
            <div class="mb-3" style="font-size: 2.5rem;">🔒</div>
            <h4 class="fw-semibold mb-2" style="color:#1a2332;">Access Denied</h4>
            <p class="text-muted small mb-4">
                You don't have permission to view this page.
                This action requires the <strong>Admin</strong> role.
            </p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-dark">Back to Home</a>
        </div>

    </div>
</div>
